// =============================================================================
// Prisma Schema — ZK Gaming Platform
// PostgreSQL 
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum SessionStatus {
  STARTED
  IN_PROGRESS
  CANCELLED
  FINISHED

  @@map("session_status")
}

/// Mirrors the status lifecycle returned by the zkVerify Kurier relayer.
enum VerificationStatus {
  QUEUED
  VALID
  SUBMITTED
  INCLUDED_IN_BLOCK
  FINALIZED
  AGGREGATION_PENDING
  AGGREGATED
  FAILED

  @@map("verification_status")
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

/// A game hosted on the platform. Circuits and sessions are owned by a game.
model Game {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  circuits Circuit[]
  sessions GameSession[]
  proofs   Proof[]

  @@map("games")
}

// -----------------------------------------------------------------------------

/// A ZK circuit belonging to a game. Stores the compiled artefact and the
/// verification key registered with zkVerify Kurier.
model Circuit {
  id              String   @id @default(uuid()) @db.Uuid
  gameId          String   @map("game_id") @db.Uuid
  /// Human-readable binary / circuit name (e.g. "battleship_move").
  circuitName     String   @map("circuit_name")
  /// Raw Nargo compiler JSON output.
  compiledCircuit Json     @map("compiled_circuit")
  /// Barretenberg (bb) verification key stored as a hex string.
  verificationKey String   @map("verification_key")
  /// Kurier vkHash for this circuit — used when submitting proofs.
  vkHash          String   @map("vk_hash")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  game   Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  proofs Proof[]

  @@index([gameId])
  @@map("circuits")
}

// -----------------------------------------------------------------------------

/// An on-chain player identified by their Ethereum address.
/// Aggregate stats (totalXp, wins) are cached here and updated after each
/// session resolves — avoids expensive full-table aggregations at read time.
model Player {
  id        String   @id // Ethereum address (checksummed, lowercase)
  totalXp   Int      @default(0) @map("total_xp")
  wins      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessionPlayers SessionPlayer[]
  proofPlayers   ProofPlayer[]

  @@map("players")
}

// =============================================================================
// SESSIONS
// =============================================================================

/// A single game session (single-player or multiplayer).
/// Players and their per-session XP / winner flags are stored in SessionPlayer.
model GameSession {
  id        String        @id @default(uuid()) @db.Uuid
  gameId    String        @map("game_id") @db.Uuid
  status    SessionStatus @default(STARTED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // Relations
  game               Game                @relation(fields: [gameId], references: [id], onDelete: Restrict)
  sessionPlayers     SessionPlayer[]
  proofs             Proof[]
  minesweeperSession MinesweeperSession?

  @@index([gameId])
  @@index([status])
  @@index([gameId, status]) // common compound filter
  @@map("game_sessions")
}

// -----------------------------------------------------------------------------

/// Junction table between GameSession and Player.
/// Carries per-session state: XP earned and whether this player is a winner.
/// Supports both single-player (one row) and multiplayer (many rows) sessions.
model SessionPlayer {
  id            String   @id @default(uuid()) @db.Uuid
  sessionId     String   @map("session_id") @db.Uuid
  playerAddress String   @map("player_address")
  xp            Int      @default(0)
  isWinner      Boolean  @default(false) @map("is_winner")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player      @relation(fields: [playerAddress], references: [id], onDelete: Restrict)

  @@unique([sessionId, playerAddress]) // one row per player per session
  @@index([sessionId])
  @@index([playerAddress])
  @@map("session_players")
}

// -----------------------------------------------------------------------------

/// Minesweeper-specific session data.
/// One-to-one extension of GameSession for minesweeper games.
/// Stores the cryptographic commitment data and generated cells.
model MinesweeperSession {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @unique @map("session_id") @db.Uuid
  seed       String
  merkleRoot String   @map("merkle_root")
  cells      Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("minesweeper_sessions")
}

// =============================================================================
// ZK PROOFS
// =============================================================================

/// A ZK proof generated during a session for one or more players.
/// Tracks the local bb verification result and links to the Kurier job.
model Proof {
  id                   String   @id @default(uuid()) @db.Uuid
  gameId               String   @map("game_id") @db.Uuid
  sessionId            String   @map("session_id") @db.Uuid
  circuitId            String   @map("circuit_id") @db.Uuid
  /// Local Barretenberg (bb) sanity-check result before on-chain submission.
  bbVerificationStatus Boolean  @map("bb_verification_status")
  /// UUID returned by the Kurier 'submit-proof' endpoint — FK to VerificationJob.
  /// Nullable until the proof has been submitted to Kurier.
  kurierJobId          String?  @unique @map("kurier_job_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  game            Game             @relation(fields: [gameId], references: [id], onDelete: Restrict)
  session         GameSession      @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  circuit         Circuit          @relation(fields: [circuitId], references: [id], onDelete: Restrict)
  proofPlayers    ProofPlayer[]
  verificationJob VerificationJob?

  @@index([gameId])
  @@index([sessionId])
  @@index([circuitId])
  @@index([kurierJobId])
  @@map("proofs")
}

// -----------------------------------------------------------------------------

/// Junction table between Proof and Player.
/// A proof can attest to moves / state for multiple players simultaneously
/// (e.g. a shared game state proof in a multiplayer session).
model ProofPlayer {
  id            String   @id @default(uuid()) @db.Uuid
  proofId       String   @map("proof_id") @db.Uuid
  playerAddress String   @map("player_address")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  proof  Proof  @relation(fields: [proofId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerAddress], references: [id], onDelete: Restrict)

  @@unique([proofId, playerAddress])
  @@index([proofId])
  @@index([playerAddress])
  @@map("proof_players")
}

// =============================================================================
// ZK VERIFICATION (zkVerify Kurier)
// =============================================================================

/// Tracks the full lifecycle of a proof verification job on zkVerify Kurier.
/// The primary key is the Kurier-issued job ID (not auto-generated by us).
/// Linked 1-to-1 with Proof via Proof.kurierJobId.
model VerificationJob {
  /// The kurier_job_id returned by the 'submit-proof' relayer endpoint.
  /// This is the authoritative identifier — never auto-generated.
  kurierJobId String @id @map("kurier_job_id") @db.Uuid

  /// Returned alongside kurier_job_id from 'submit-proof'.
  optimisticVerify Boolean @map("optimistic_verify")

  /// Nullable — populated as Kurier pushes status updates.
  verificationStatus VerificationStatus? @map("verification_status")

  /// On-chain transaction hash — populated once SUBMITTED or later.
  txHash String? @map("tx_hash")

  /// Aggregation batch ID — populated when AGGREGATION_PENDING or later.
  aggregationId Int? @map("aggregation_id")

  /// Full aggregation metadata returned by Kurier (flexible JSON).
  aggregationDetails Json? @map("aggregation_details")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  proof Proof @relation(fields: [kurierJobId], references: [kurierJobId])

  @@index([verificationStatus])
  @@index([aggregationId])
  @@map("verification_jobs")
}